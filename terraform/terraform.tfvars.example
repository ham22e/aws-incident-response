# 이 파일을 복사해 terraform.tfvars 로 만들고 값을 채운다. (terraform.tfvars 는 gitignore 됨)
region      = "ap-northeast-2"
aws_profile = "default"    # 사용하는 AWS CLI 프로파일명. 기본 자격증명 체인을 쓰면 이 줄 삭제.
my_ip       = "X.X.X.X/32" # 본인 공인 IP. 확인: curl -s ifconfig.me
prefix      = "cloudir"
alert_email = "you@example.com" # 비용 경보 이메일. 안 쓰면 이 줄 삭제.
